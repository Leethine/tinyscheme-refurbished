# $Id: devkitPro.env,v 1.1 2021/08/06 17:39:12 alex Exp alex $
#*******************************************************************************
#
#    Environment Variables for NDS Development under Linux
#    -----------------------------------------------------
#
#    I install the NDS development kits under the devkitPro umbrella
#    in the "/opt" directory.  I also install the source code for
#    Ficl and tinyscheme  in the "/opt" directory.
#
#        /opt
#        /opt/devkitARMr41
#        ...
#        /opt/devkitARMr45
#        /opt/devkitARM -> devkitARMr45			(Symbolic link)
#        ...
#        /opt/devkitPro -> devkitARM			(Symbolic link)
#        ...
#        /opt/ficl4.1.0
#        /opt/ficl -> ficl-4.1.0			(Symbolic link)
#        ...
#        /opt/tinyscheme-1.40
#        /opt/tinyscheme-1.41
#        /opt/tinyscheme -> tinyscheme-1.41		(Symbolic link)
#        ...
#
#    I build the executables and libraries for Ficl and TinyScheme in
#    parallel object directories generated using the "lndir" command.
#    (The object directories contain links to the source files.)
#
#        /opt/obj/ndsr41
#        ...
#        /opt/obj/ndsr45
#        /opt/obj/nds -> ndsr45				(Symbolic link)
#        ...
#        /opt/obj/ndsr45/ficl
#        /opt/obj/nds/ficl
#            Resolves to "ndsr45/ficl".  The "source files"
#            in the "ndsr45/ficl" directory are symbolic
#            links to the corresponding, actual source files
#            in "/opt/ficl" (i.e., "/opt/ficl-4.1.0").
#        ...
#        /opt/obj/ndsr45/tinyscheme
#        /opt/obj/nds/tinyscheme
#            Resolves to "ndsr45/tinyscheme".  The "source files"
#            in the "ndsr45/tinyscheme" directory are symbolic
#            links to the corresponding, actual source files in
#            "/opt/tinyscheme" (i.e., "/opt/tinyscheme-1.41").
#        ...
#        /opt/obj/x86_64linux
#            For illustrative purposes, another parallel object
#            directory for building the programs and libraries
#            under Linux.
#
#*******************************************************************************

setenv DEVKITPRO /opt/devkitPro
setenv DEVKITARM $DEVKITPRO/devkitARM
