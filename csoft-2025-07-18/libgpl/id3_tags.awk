#! /usr/bin/awk -f
#
# $Id$
#
################################################################################
#
#    ID3_TAGS -generates entries in a tag information table.
#
################################################################################

BEGIN {
    FS = "|"
}


/^ID3_/ {
    f1 = $1

    if ($2 == "")
        f2 = "NULL"
    else
        f2 = "\"" $2 "\""

    if ($3 == "")
        f3 = "NULL"
    else
        f3 = "\"" $3 "\""

    if ($4 == "")
        f4 = "NULL"
    else
        f4 = "\"" $4 "\""

    if ($5 == "")
        f5 = 0
    else
        f5 = $5

    printf "{ %s, %s, %s, %s, %s },\n", f1, f2, f3, f4, f5
}
